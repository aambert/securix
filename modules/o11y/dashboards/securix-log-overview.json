{
  "uid": "securix-logs",
  "title": "Sécurix — Log Overview",
  "tags": ["securix", "logs", "vector"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "annotations": { "list": [] },
  "templating": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total events (range)",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "grafana-opensearch-datasource", "uid": "opensearch" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-opensearch-datasource", "uid": "opensearch" },
          "query": "*",
          "queryType": "lucene",
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": [
            { "id": "2", "type": "date_histogram", "field": "timestamp", "settings": { "interval": "1h", "min_doc_count": "0" } }
          ]
        }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["sum"] },
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Auditd events",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "grafana-opensearch-datasource", "uid": "opensearch" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-opensearch-datasource", "uid": "opensearch" },
          "query": "source_type:auditd",
          "queryType": "lucene",
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": [
            { "id": "2", "type": "date_histogram", "field": "timestamp", "settings": { "interval": "1h", "min_doc_count": "0" } }
          ]
        }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["sum"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "orange" } },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Journal events (systemd)",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "grafana-opensearch-datasource", "uid": "opensearch" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-opensearch-datasource", "uid": "opensearch" },
          "query": "source_type:journald",
          "queryType": "lucene",
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": [
            { "id": "2", "type": "date_histogram", "field": "timestamp", "settings": { "interval": "1h", "min_doc_count": "0" } }
          ]
        }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["sum"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Events per minute by source",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "grafana-opensearch-datasource", "uid": "opensearch" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-opensearch-datasource", "uid": "opensearch" },
          "query": "*",
          "queryType": "lucene",
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": [
            { "id": "3", "type": "terms", "field": "source_type.keyword", "settings": { "size": "10", "min_doc_count": "1", "order": "desc", "orderBy": "_count" } },
            { "id": "2", "type": "date_histogram", "field": "timestamp", "settings": { "interval": "auto" } }
          ]
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 70, "stacking": { "mode": "normal" } } },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "piechart",
      "title": "Share by syslog identifier",
      "gridPos": { "x": 0, "y": 4, "w": 6, "h": 8 },
      "datasource": { "type": "grafana-opensearch-datasource", "uid": "opensearch" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-opensearch-datasource", "uid": "opensearch" },
          "query": "*",
          "queryType": "lucene",
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": [
            { "id": "2", "type": "terms", "field": "SYSLOG_IDENTIFIER.keyword", "settings": { "size": "10", "min_doc_count": "1" } }
          ]
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "right", "values": ["value", "percent"] },
        "pieType": "donut"
      }
    },
    {
      "id": 6,
      "type": "barchart",
      "title": "Top systemd units",
      "gridPos": { "x": 6, "y": 4, "w": 6, "h": 8 },
      "datasource": { "type": "grafana-opensearch-datasource", "uid": "opensearch" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-opensearch-datasource", "uid": "opensearch" },
          "query": "*",
          "queryType": "lucene",
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": [
            { "id": "2", "type": "terms", "field": "_SYSTEMD_UNIT.keyword", "settings": { "size": "15", "min_doc_count": "1", "order": "desc", "orderBy": "_count" } }
          ]
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "orientation": "horizontal" } },
        "overrides": []
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Events per minute by syslog priority",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "grafana-opensearch-datasource", "uid": "opensearch" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-opensearch-datasource", "uid": "opensearch" },
          "query": "*",
          "queryType": "lucene",
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": [
            { "id": "3", "type": "terms", "field": "PRIORITY.keyword", "settings": { "size": "10", "min_doc_count": "1" } },
            { "id": "2", "type": "date_histogram", "field": "timestamp", "settings": { "interval": "auto" } }
          ]
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20 } },
        "overrides": []
      }
    },
    {
      "id": 8,
      "type": "table",
      "title": "Recent log events (latest 100)",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 12 },
      "datasource": { "type": "grafana-opensearch-datasource", "uid": "opensearch" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-opensearch-datasource", "uid": "opensearch" },
          "query": "*",
          "queryType": "lucene",
          "metrics": [{ "id": "1", "type": "raw_data", "settings": { "size": "100" } }],
          "bucketAggs": []
        }
      ]
    }
  ]
}
